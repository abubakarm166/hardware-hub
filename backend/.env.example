DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true

# Comma-separated hostnames (no scheme). Include your API host, e.g. hardware-hub-td6s.vercel.app
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Production: set false so API errors are not HTML debug pages
# DJANGO_DEBUG=false

# --- Database ---
# Local: SQLite (default)
USE_SQLITE=true

# Production (Vercel / serverless): PostgreSQL URL — SQLite will fail with OperationalError
# Get a free DB from Neon, Supabase, or Railway, then:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# USE_SQLITE=false

# PostgreSQL without DATABASE_URL (when USE_SQLITE=false)
POSTGRES_DB=hardware_hub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS — your Next.js origin(s), https, no trailing slash
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional — Django admin on HTTPS
# CSRF_TRUSTED_ORIGINS=https://hardware-hub-td6s.vercel.app

# Local: after STATIC_ROOT is set, run: python manage.py collectstatic
