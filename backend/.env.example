DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true

# Comma-separated hostnames (no scheme). Include your API host (e.g. Vercel URL).
# On Railway, RAILWAY_PUBLIC_DOMAIN is merged automatically — you can still set this for localhost + prod.
# You may paste https://... — scheme/path are stripped automatically.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: one extra hostname without editing the list above
# PUBLIC_HOSTNAME=example.up.railway.app

# Production: set false so API errors are not HTML debug pages
# DJANGO_DEBUG=false

# --- Database ---
# Local: SQLite (default)
USE_SQLITE=true

# Production (Vercel / serverless): PostgreSQL URL — SQLite will fail with OperationalError
# Get a free DB from Neon, Supabase, or Railway, then:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# USE_SQLITE=false

# PostgreSQL without DATABASE_URL (when USE_SQLITE=false)
POSTGRES_DB=hardware_hub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS — your Next.js origin(s), https, no trailing slash
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional — extra trusted origins (comma-separated, https, no trailing slash).
# Railway HTTPS origin is merged from RAILWAY_PUBLIC_DOMAIN / ALLOWED_HOSTS automatically.
# Add your Vercel site if browsers POST directly to Django (not needed for Next.js server-side proxy):
# CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app

# Local: after STATIC_ROOT is set, run: python manage.py collectstatic
# Production (Docker/Railway): collectstatic runs in deploy_start.sh; WhiteNoise serves admin CSS.

# --- One-time bootstrap (set on Railway, then remove or set BOOTSTRAP_ADMIN=0) ---
# Creates superuser if missing. Weak passwords allowed via set_password — change in admin after login.
# BOOTSTRAP_ADMIN=1
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=admin
# SEED_DUMMY_DATA=1
