DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true

# Comma-separated hostnames Django will accept (no scheme, no path).
# Local dev:
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Production example — include your API host (e.g. Vercel serverless / Railway):
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,hardware-hub-td6s.vercel.app
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Use SQLite for local dev (default true). Set false to use PostgreSQL.
USE_SQLITE=true

# PostgreSQL (when USE_SQLITE=false)
POSTGRES_DB=hardware_hub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS — origins allowed to call the API from the browser (scheme + host, no trailing slash).
# Include your Next.js frontend URL(s), e.g.:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://hardware-hub-d14w.vercel.app
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional — HTTPS origins for Django admin / CSRF when DEBUG=false (comma-separated).
# CSRF_TRUSTED_ORIGINS=https://hardware-hub-td6s.vercel.app
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,hardware-hub-td6s.vercel.app,hardware-hub-production-0445.up.railway.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://hardware-hub-d14w.vercel.app


# VISION_WARRANTY_API_URL=https://your-vision-or-middleware-host/path
# optional:
# VISION_WARRANTY_API_KEY=...
# VISION_WARRANTY_API_TIMEOUT=15
# VISION_WARRANTY_VERIFY_SSL=true
# VISION_WARRANTY_FALLBACK_STUB=true